{
  "providers": [
    {
      "id": "chatgpt",
      "name": "ChatGPT",
      "description": "OpenAI ChatGPT via browser automation",
      "headless": false,
      "profileDir": "chatgpt",
      "viewport": { "width": 1280, "height": 720 },
      "defaultTimeout": 30000,
      "maxSessions": 1,
      "blockedDomains": [],
      "allowedDomains": ["chatgpt.com", "chat.openai.com"],
      "url": "https://chatgpt.com",
      "enabled": true,
      "defaultMode": "interact",
      "submitStrategy": "enter",
      "inputSelectors": ["textarea", "[contenteditable='true']", "[role='textbox']"],
      "responseSelectors": ["[data-message-author-role='assistant']", ".markdown", "main"]
    },
    {
      "id": "claude",
      "name": "Claude",
      "description": "Anthropic Claude via browser automation",
      "headless": false,
      "profileDir": "claude",
      "viewport": { "width": 1280, "height": 720 },
      "defaultTimeout": 30000,
      "maxSessions": 1,
      "blockedDomains": [],
      "allowedDomains": ["claude.ai"],
      "url": "https://claude.ai",
      "enabled": true,
      "defaultMode": "interact",
      "submitStrategy": "enter",
      "inputSelectors": ["textarea", "[contenteditable='true']", "[role='textbox']", "div.ProseMirror"],
      "responseSelectors": [".font-claude-message", "[data-testid='assistant-message']", "main"]
    },
    {
      "id": "gemini",
      "name": "Gemini",
      "description": "Google Gemini via browser automation",
      "headless": false,
      "profileDir": "gemini",
      "viewport": { "width": 1280, "height": 720 },
      "defaultTimeout": 30000,
      "maxSessions": 1,
      "blockedDomains": [],
      "allowedDomains": ["gemini.google.com"],
      "url": "https://gemini.google.com",
      "enabled": true,
      "defaultMode": "interact",
      "submitStrategy": "enter",
      "inputSelectors": ["textarea", "[contenteditable='true']", "[role='textbox']", "div.ql-editor"],
      "responseSelectors": ["model-response", "message-content", "main"]
    },
    {
      "id": "zai",
      "name": "ZAI",
      "description": "Z.AI via browser automation",
      "headless": false,
      "profileDir": "zai",
      "viewport": { "width": 1280, "height": 720 },
      "defaultTimeout": 30000,
      "maxSessions": 1,
      "blockedDomains": [],
      "allowedDomains": ["chat.z.ai", "z.ai"],
      "url": "https://chat.z.ai",
      "enabled": true,
      "defaultMode": "interact",
      "submitStrategy": "enter",
      "inputSelectors": ["textarea", "[contenteditable='true']", "[role='textbox']"],
      "responseSelectors": ["[data-message-role='assistant']", ".assistant-message", "main"]
    },
    {
      "id": "custom",
      "name": "Custom Browser",
      "description": "Default headful browser with persistent profile for manual login and automation",
      "headless": false,
      "profileDir": "custom",
      "viewport": { "width": 1280, "height": 720 },
      "defaultTimeout": 30000,
      "maxSessions": 1,
      "blockedDomains": [],
      "allowedDomains": [],
      "enabled": true,
      "defaultMode": "navigate"
    }
  ]
}
