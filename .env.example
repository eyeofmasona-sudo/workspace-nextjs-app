# Database — SQLite file path (relative to project root)
DATABASE_URL="file:./db/custom.db"

# OpenRouter — get your key at https://openrouter.ai
OPENROUTER_API_KEY="sk-or-your-key-here"
OPENROUTER_BASE_URL="https://openrouter.ai/api/v1"

# Optional: restrict Browser Operator API (leave empty = open in dev mode)
# BROWSER_OPERATOR_API_KEY="your-secret-key"

# Telegram Bot (optional — run: npm run bot)
# Get token from @BotFather on Telegram
TELEGRAM_BOT_TOKEN="123456789:ABCdef..."
# Optional: restrict bot to specific chat IDs (comma-separated)
# TELEGRAM_ALLOWED_CHATS="123456789,987654321"
# Optional: override orchestrator URL (default: http://localhost:3000/api/orchestrator/chat)
# ORCHESTRATOR_URL="http://localhost:3000/api/orchestrator/chat"
# Optional: request timeout in ms (default: 120000)
# ORCHESTRATOR_TIMEOUT_MS="120000"
