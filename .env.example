# Database — SQLite file path (relative to project root)
DATABASE_URL="file:./db/custom.db"

# OpenRouter — get your key at https://openrouter.ai
OPENROUTER_API_KEY="sk-or-your-key-here"
OPENROUTER_BASE_URL="https://openrouter.ai/api/v1"

# Optional: restrict Browser Operator API (leave empty = open in dev mode)
# BROWSER_OPERATOR_API_KEY="your-secret-key"

# Telegram Bot (optional — run: npm run bot)
# Get token from @BotFather on Telegram
TELEGRAM_BOT_TOKEN="123456789:ABCdef..."
# Optional: restrict bot to specific chat IDs (comma-separated)
# TELEGRAM_ALLOWED_CHATS="123456789,987654321"
# Optional: override orchestrator URL (default: http://localhost:3000/api/orchestrator/chat)
# ORCHESTRATOR_URL="http://localhost:3000/api/orchestrator/chat"
# Optional: request timeout in ms (default: 120000)
# ORCHESTRATOR_TIMEOUT_MS="120000"

# NextAuth — required for API authentication
# Generate: openssl rand -base64 32
NEXTAUTH_SECRET="your-secret-here"
NEXTAUTH_URL="http://localhost:3000"
# Single-user password for local Agent OS access
AGENT_OS_PASSWORD="changeme"

# Rate limiting — optional Upstash Redis (recommended for production)
# Without these, falls back to in-memory token bucket (single-instance only)
# Get credentials at https://console.upstash.com
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""

# Structured logging (pino)
# LOG_LEVEL=info  # debug | info | warn | error (default: debug in dev, info in prod)

# Sentry error tracking (optional — omit to disable)
SENTRY_DSN=""
SENTRY_TRACES_SAMPLE_RATE="0.1"
