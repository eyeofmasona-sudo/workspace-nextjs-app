// Agent OS — Foundation Schema
// Single-user now, SaaS-ready architecture

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// ─── Core Entities ───────────────────────────────────────────

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String?
  settings  String? // JSON: flexible user settings
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  workspaces Workspace[]

  @@map("users")
}

model Workspace {
  id        String   @id @default(cuid())
  ownerId   String
  name      String
  mode      String   @default("single") // single | team | saas
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  owner    User      @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  projects Project[]
  agents   Agent[]

  @@map("workspaces")
}

model Project {
  id          String   @id @default(cuid())
  workspaceId String
  name        String
  description String?
  sourceType  String   @default("local") // local | git | cloud
  sourcePath  String?
  repoUrl     String?
  status      String   @default("active") // active | archived | deleted
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  epics     Epic[]

  @@map("projects")
}

model Epic {
  id          String   @id @default(cuid())
  projectId   String
  title       String
  description String?
  status      String   @default("planned") // backlog | planned | in_progress | review | done | cancelled
  priority    String   @default("medium") // low | medium | high | critical
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  tasks   Task[]

  @@map("epics")
}

model Task {
  id               String   @id @default(cuid())
  epicId           String
  parentTaskId     String?
  title            String
  description      String?
  status           String   @default("backlog") // backlog | planned | in_progress | review | waiting_approval | done | failed | cancelled
  priority         String   @default("medium") // low | medium | high | critical
  assignedAgentId  String?
  riskLevel        String   @default("low") // low | medium | high | critical
  requiresApproval Boolean  @default(false)
  costEstimate     Float?
  costActual       Float?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  epic             Epic              @relation(fields: [epicId], references: [id], onDelete: Cascade)
  parentTask       Task?             @relation("TaskSubtasks", fields: [parentTaskId], references: [id], onDelete: SetNull)
  subtasks         Task[]            @relation("TaskSubtasks")
  assignedAgent    Agent?            @relation("TaskAssignee", fields: [assignedAgentId], references: [id], onDelete: SetNull)
  approvalRequests ApprovalRequest[]
  costLogs         CostLog[]

  @@map("tasks")
}

model Agent {
  id                String   @id @default(cuid())
  workspaceId       String
  name              String
  role              String
  type              String   @default("permanent") // permanent | temporary
  visualProfile     String? // JSON: appearance, avatar config
  professionalStyle String? // JSON: behavior, communication style
  systemPrompt      String? // System prompt for AI model
  status            String   @default("offline") // idle | thinking | working | waiting_api | reviewing | waiting_approval | done | error | offline
  locationZone      String   @default("lounge_area") // command_area | situation_room | development_area | design_area | research_area | server_room | meeting_room | lounge_area
  activeTaskId      String? // Currently active task (not FK to avoid circular)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  workspace        Workspace          @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  tasks            Task[]             @relation("TaskAssignee")
  approvalRequests ApprovalRequest[]
  costLogs         CostLog[]
  profile          AgentProfile?
  capabilities     AgentCapability[]
  modelConfigs     AgentModelConfig[]
  permissions      AgentPermission[]
  runtimeState     AgentRuntimeState?
  memoryLinks      AgentMemoryLink[]

  @@map("agents")
}

// ─── Agent System ───────────────────────────────────────────────

model AgentProfile {
  id               String   @id @default(cuid())
  agentId          String   @unique
  displayName      String
  avatarKey        String? // avatar identifier / emoji
  bio              String? // Professional bio
  seniority        String   @default("senior") // junior | mid | senior | lead | principal
  workingStyle     String? // JSON: preferences, habits
  strengths        String? // JSON: array of strengths
  limitations      String? // JSON: array of limitations
  responsibilities String? // JSON: array of responsibilities
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  agent Agent @relation(fields: [agentId], references: [id], onDelete: Cascade)

  @@map("agent_profiles")
}

model AgentCapability {
  id            String   @id @default(cuid())
  agentId       String
  capabilityKey String // orchestration | product_analysis | frontend_development | etc.
  level         String   @default("intermediate") // basic | intermediate | advanced | expert
  enabled       Boolean  @default(true)
  metadata      String? // JSON
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  agent Agent @relation(fields: [agentId], references: [id], onDelete: Cascade)

  @@unique([agentId, capabilityKey])
  @@map("agent_capabilities")
}

model AgentModelConfig {
  id             String   @id @default(cuid())
  agentId        String
  provider       String // openai | anthropic | google | local | openrouter
  model          String // gpt-4o | claude-3.5-sonnet | gemini-pro | etc.
  preferenceType String   @default("preferred") // preferred | fallback
  maxCostPerTask Float?
  maxTokens      Int?
  enabled        Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  agent Agent @relation(fields: [agentId], references: [id], onDelete: Cascade)

  @@map("agent_model_configs")
}

model AgentPermission {
  id              String   @id @default(cuid())
  agentId         String
  permissionKey   String // files | terminal | git | database | browser | documents | rag | ocr | translation | deployment | secrets | payments
  permissionLevel String   @default("none") // none | read | write | admin
  constraints     String? // JSON: additional constraints
  enabled         Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  agent Agent @relation(fields: [agentId], references: [id], onDelete: Cascade)

  @@unique([agentId, permissionKey])
  @@map("agent_permissions")
}

model AgentRuntimeState {
  id              String   @id @default(cuid())
  agentId         String   @unique
  status          String   @default("offline") // mirrors Agent.status
  locationZone    String   @default("lounge_area")
  activeTaskId    String? // Currently active task
  lastActivityAt  DateTime @default(now())
  currentActivity String? // Description of current activity
  metadata        String? // JSON: extended runtime info
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  agent Agent @relation(fields: [agentId], references: [id], onDelete: Cascade)

  @@map("agent_runtime_states")
}

model AgentMemoryLink {
  id           String   @id @default(cuid())
  agentId      String
  memoryItemId String
  relevance    Float    @default(1.0) // 0.0–1.0 relevance score
  createdAt    DateTime @default(now())

  agent      Agent      @relation(fields: [agentId], references: [id], onDelete: Cascade)
  memoryItem MemoryItem @relation(fields: [memoryItemId], references: [id], onDelete: Cascade)

  @@unique([agentId, memoryItemId])
  @@map("agent_memory_links")
}

// ─── Memory System ───────────────────────────────────────────

model MemoryItem {
  id        String   @id @default(cuid())
  scope     String // global | workspace | project | agent | task
  scopeId   String? // ID of the scope entity (workspace_id, project_id, etc.)
  type      String // context | decision | fact | lesson | conversation_summary | error
  content   String
  metadata  String? // JSON
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  agentLinks AgentMemoryLink[]

  @@map("memory_items")
}

// ─── Approval System ─────────────────────────────────────────

model ApprovalRequest {
  id          String   @id @default(cuid())
  taskId      String?  // Optional: null when approval is for a tool execution without task context
  workspaceId String?  // Direct workspace reference for task-independent approvals
  agentId     String
  actionType  String // execute | deploy | delete | modify | spend | access
  summary     String
  risk        String   @default("medium") // low | medium | high | critical
  payload     String? // JSON: action details
  status      String   @default("pending") // pending | approved | rejected | expired
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  task           Task?            @relation(fields: [taskId], references: [id], onDelete: SetNull)
  agent          Agent            @relation(fields: [agentId], references: [id], onDelete: Cascade)
  toolExecutions ToolExecution[]

  @@map("approval_requests")
}

// ─── Event Log ───────────────────────────────────────────────

model EventLog {
  id         String   @id @default(cuid())
  eventType  String
  entityType String? // project | epic | task | agent | approval | memory | cost
  entityId   String?
  payload    String? // JSON
  createdAt  DateTime @default(now())

  @@map("event_logs")
}

// ─── Cost Tracking ───────────────────────────────────────────

model CostLog {
  id        String   @id @default(cuid())
  agentId   String
  taskId    String?
  provider  String? // openai | anthropic | google | local | etc.
  model     String?
  tokensIn  Int      @default(0)
  tokensOut Int      @default(0)
  cost      Float    @default(0)
  createdAt DateTime @default(now())

  agent Agent @relation(fields: [agentId], references: [id], onDelete: Cascade)
  task  Task? @relation(fields: [taskId], references: [id], onDelete: SetNull)

  @@map("cost_logs")
}

// ─── Tool Hub ────────────────────────────────────────────────

model Tool {
  id               String   @id @default(cuid())
  workspaceId      String? // null = global tool
  name             String
  key              String // unique per workspace/global, e.g. "filesystem.read"
  category         String // model_provider | filesystem | terminal | git | browser | database | document | ocr | translation | rag | deployment | notification | media | cost | internal
  description      String?
  configSchema     String? // JSON: expected input schema
  enabled          Boolean  @default(true)
  riskLevel        String   @default("low") // low | medium | high | critical
  requiresApproval Boolean  @default(false)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  policies   ToolPermissionPolicy[]
  executions ToolExecution[]

  @@unique([key, workspaceId])
  @@map("tools")
}

model ToolExecution {
  id                String    @id @default(cuid())
  workspaceId       String
  agentId           String?
  taskId            String?
  toolId            String
  action            String // e.g. "read", "write", "run", "deploy"
  correlationId     String? // Links orchestrator → tool events for UI animation correlation
  inputSummary      String? // JSON: safe summary of input
  outputSummary     String? // JSON: safe summary of output
  status            String    @default("pending") // pending | running | success | failed | blocked | requires_approval
  riskLevel         String    @default("low") // low | medium | high | critical
  approvalRequestId String? // FK to ApprovalRequest if requires_approval
  errorMessage      String?
  metadata          String? // JSON: extended execution info
  startedAt         DateTime  @default(now())
  completedAt       DateTime?
  createdAt         DateTime  @default(now())

  tool            Tool             @relation(fields: [toolId], references: [id], onDelete: Cascade)
  approvalRequest ApprovalRequest? @relation(fields: [approvalRequestId], references: [id], onDelete: SetNull)

  @@map("tool_executions")
}

model ToolPermissionPolicy {
  id            String   @id @default(cuid())
  toolId        String
  permissionKey String // maps to AgentPermission.permissionKey
  requiredLevel String   @default("read") // none | read | write | admin
  constraints   String? // JSON: additional constraints
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  tool Tool @relation(fields: [toolId], references: [id], onDelete: Cascade)

  @@unique([toolId, permissionKey])
  @@map("tool_permission_policies")
}
