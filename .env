DATABASE_URL=file:/home/z/my-project/db/custom.db

# ─── AI Provider Configuration ─────────────────────────────────
# OpenRouter API Key — get yours at https://openrouter.ai/keys
# This is the primary AI provider for all agents.
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_SITE_URL=http://localhost:3000
OPENROUTER_SITE_NAME=Agent OS
OPENROUTER_TIMEOUT_MS=60000

# ─── Browser Operator Module ────────────────────────────────────
# Optional API key for browser operator endpoints.
# Leave empty in dev for open access. Set for production.
BROWSER_OPERATOR_API_KEY=
